# Strava API credentials
# Obtain from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8000/callback

# Telegram bot credentials
# Create a bot via @BotFather and get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Anthropic API key — used by /setplan to generate training plans
# Obtain from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Claude model to use for AI features (default: claude-sonnet-4-6)
CLAUDE_MODEL=

# Seconds between automatic Strava syncs in the bot (default: 1800 = 30 min)
STRAVA_POLL_INTERVAL=1800

# Seconds to wait before auto-analysing a new activity (default: 600 = 10 min)
STRAVA_ANALYSIS_DELAY=600

# Hour (UTC) for the daily morning check-in message (default: 8 = 08:00 UTC)
MORNING_CHECKIN_HOUR=8

# Set to "json" for structured JSON log output (default: text)
# LOG_FORMAT=json
